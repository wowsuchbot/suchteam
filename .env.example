# Database
DATABASE_URL=ecto://postgres:postgres@localhost:5433/suchteam_dev

# Redis (optional)
REDIS_URL=redis://localhost:6379

# OpenClaw (optional - for agent integration)
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_HTTP_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=dev_token

# Phoenix
PHX_HOST=localhost
PORT=4000

# IMPORTANT: Generate a secure secret key base for production
# Run: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here

# SaaS Settings (Production)
# SAAS_MODE=true
# REQUIRE_EMAIL_VERIFICATION=false
# ALLOW_REGISTRATION=true

# Billing (if using Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (for notifications - optional)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# FROM_EMAIL=noreply@suchteam.dev

